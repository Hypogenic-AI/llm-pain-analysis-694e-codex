{"type":"item.started","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport json, os\nfrom pathlib import Path\nfrom datasets import load_dataset, DatasetDict\n\nos.makedirs('datasets', exist_ok=True)\n\nplans = [\n    {\n        'key':'hh_rlhf',\n        'hf':'Anthropic/hh-rlhf',\n        'splits':['train','test'],\n        'task':'helpful/harmless preference and refusal behavior'\n    },\n    {\n        'key':'toxic_chat',\n        'hf':'lmsys/toxic-chat',\n        'splits':['train','test'],\n        'task':'toxic prompt safety classification and refusal risk'\n    },\n    {\n        'key':'truthful_qa',\n        'hf':'truthful_qa',\n        'config':'generation',\n        'splits':['validation'],\n        'task':'truthfulness vs refusal/avoidance tradeoff'\n    }\n]\n\nsummary=[]\nfor p in plans:\n    key=p['key']\n    target=Path('datasets')/key\n    sample_dir=target/'samples'\n    sample_dir.mkdir(parents=True, exist_ok=True)\n    kwargs={}\n    if 'config' in p: kwargs['name']=p['config']\n\n    dd=DatasetDict()\n    split_sizes={}\n    features={}\n    for split in p['splits']:\n        ds=load_dataset(p['hf'], split=split, **kwargs)\n        dd[split]=ds\n        split_sizes[split]=len(ds)\n        features[split]=list(ds.features.keys())\n        sample=ds.select(range(min(10,len(ds))))\n        with open(sample_dir/f'{split}_sample.json','w') as f:\n            json.dump(sample.to_list(), f, indent=2, ensure_ascii=False)\n\n    dd.save_to_disk(str(target/'hf_disk'))\n\n    summary.append({\n        'name': key,\n        'hf': p['hf'] + (f\\\":{p['config']}\\\" if 'config' in p else ''),\n        'task': p['task'],\n        'location': str(target/'hf_disk'),\n        'split_sizes': split_sizes,\n        'features': features,\n    })\n\nwith open('datasets/dataset_summary.json','w') as f:\n    json.dump(summary,f,indent=2)\n\nprint('downloaded datasets:', len(summary))\nfor s in summary:\n    print(s['name'], s['split_sizes'])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
