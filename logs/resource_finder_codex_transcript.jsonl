{"type":"item.started","item":{"id":"item_28","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport json, os\nfrom pathlib import Path\nfrom datasets import load_dataset, DatasetDict, load_from_disk\n\nos.makedirs('datasets', exist_ok=True)\nsummary=[]\n\n# HH-RLHF already downloaded in prior run; reuse if present\nhh_path=Path('datasets/hh_rlhf/hf_disk')\nif hh_path.exists():\n    hh=load_from_disk(str(hh_path))\n    summary.append({\n        'name':'hh_rlhf',\n        'hf':'Anthropic/hh-rlhf',\n        'task':'helpful/harmless preference and refusal behavior',\n        'location':str(hh_path),\n        'split_sizes':{k:len(v) for k,v in hh.items()},\n        'features':{k:list(v.features.keys()) for k,v in hh.items()},\n    })\nelse:\n    dd=DatasetDict({\n        'train':load_dataset('Anthropic/hh-rlhf', split='train'),\n        'test':load_dataset('Anthropic/hh-rlhf', split='test'),\n    })\n    target=Path('datasets/hh_rlhf')\n    (target/'samples').mkdir(parents=True, exist_ok=True)\n    for split,ds in dd.items():\n        with open(target/'samples'/f'{split}_sample.json','w') as f:\n            json.dump(ds.select(range(min(10,len(ds)))).to_list(), f, indent=2)\n    dd.save_to_disk(str(target/'hf_disk'))\n    summary.append({\n        'name':'hh_rlhf','hf':'Anthropic/hh-rlhf','task':'helpful/harmless preference and refusal behavior',\n        'location':str(target/'hf_disk'),'split_sizes':{k:len(v) for k,v in dd.items()},\n        'features':{k:list(v.features.keys()) for k,v in dd.items()},\n    })\n\n# ToxicChat\nkey='toxic_chat'\ntarget=Path('datasets')/key\n(target/'samples').mkdir(parents=True, exist_ok=True)\ndd=DatasetDict({\n    'train':load_dataset('lmsys/toxic-chat','toxicchat0124', split='train'),\n    'test':load_dataset('lmsys/toxic-chat','toxicchat0124', split='test'),\n})\nfor split,ds in dd.items():\n    with open(target/'samples'/f'{split}_sample.json','w') as f:\n        json.dump(ds.select(range(min(10,len(ds)))).to_list(), f, indent=2)\ndd.save_to_disk(str(target/'hf_disk'))\nsummary.append({\n    'name':key,\n    'hf':'lmsys/toxic-chat:toxicchat0124',\n    'task':'toxic prompt safety classification and refusal risk',\n    'location':str(target/'hf_disk'),\n    'split_sizes':{k:len(v) for k,v in dd.items()},\n    'features':{k:list(v.features.keys()) for k,v in dd.items()},\n})\n\n# TruthfulQA\nkey='truthful_qa'\ntarget=Path('datasets')/key\n(target/'samples').mkdir(parents=True, exist_ok=True)\ndd=DatasetDict({'validation':load_dataset('truthful_qa','generation', split='validation')})\nfor split,ds in dd.items():\n    with open(target/'samples'/f'{split}_sample.json','w') as f:\n        json.dump(ds.select(range(min(10,len(ds)))).to_list(), f, indent=2)\ndd.save_to_disk(str(target/'hf_disk'))\nsummary.append({\n    'name':key,\n    'hf':'truthful_qa:generation',\n    'task':'truthfulness vs refusal/avoidance tradeoff',\n    'location':str(target/'hf_disk'),\n    'split_sizes':{k:len(v) for k,v in dd.items()},\n    'features':{k:list(v.features.keys()) for k,v in dd.items()},\n})\n\nwith open('datasets/dataset_summary.json','w') as f:\n    json.dump(summary,f,indent=2)\n\nprint('downloaded datasets:',len(summary))\nfor s in summary:\n    print(s['name'], s['split_sizes'])\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
