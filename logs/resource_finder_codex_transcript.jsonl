ontinue\n    title=p['title']\n    year=p.get('year')\n    sid=get_s2_id(p.get('url',''))\n    meta=None\n    if sid:\n        meta=s2_lookup_by_id(sid)\n    if not meta:\n        meta=s2_lookup_by_title(title)\n    ext=(meta or {}).get('externalIds') or {}\n    oapdf=((meta or {}).get('openAccessPdf') or {}).get('url')\n    arxiv_id=ext.get('ArXiv')\n    doi=ext.get('DOI')\n\n    candidates=[]\n    if oapdf: candidates.append(oapdf)\n    if arxiv_id: candidates.append(f'https://arxiv.org/pdf/{arxiv_id}.pdf')\n    if p.get('url','').endswith('.pdf'): candidates.append(p['url'])\n\n    base=f\\\"{year or 'unk'}_{sanitize(title)}\\\"\n    out=f'papers/{base}.pdf'\n    ok=False\n    for c in candidates:\n        if try_download(c,out):\n            ok=True; break\n\n    records.append({\n        'title': title,\n        'year': year,\n        'authors': p.get('authors',''),\n        'relevance': p.get('relevance',0),\n        'citations': p.get('citations',0),\n        'source_url': p.get('url',''),\n        'semantic_id': sid,\n        'doi': doi,\n        'arxiv_id': arxiv_id,\n        'pdf_file': out if ok else None,\n        'downloaded': ok,\n    })\n    time.sleep(0.2)\n\nwith open('papers/paper_metadata.json','w') as f:\n    json.dump(records,f,indent=2)\n\nprint('target_relevance>=2:',len(records))\nprint('downloaded:',sum(1 for r in records if r['downloaded']))\nprint('not_downloaded:',sum(1 for r in records if not r['downloaded']))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
