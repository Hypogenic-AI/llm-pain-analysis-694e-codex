{"type":"item.started","item":{"id":"item_18","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport json, os, re, requests, time\nfrom urllib.parse import quote\n\nmeta_path='papers/paper_metadata.json'\nrecords=json.load(open(meta_path))\ns=requests.Session(); s.headers.update({'User-Agent':'resource-finder/1.0'})\n\ndef try_download(url,out):\n    if not url: return False\n    try:\n        r=s.get(url,timeout=60,allow_redirects=True)\n        ct=(r.headers.get('content-type') or '').lower()\n        if r.status_code==200 and (url.lower().endswith('.pdf') or 'pdf' in ct or r.content[:4]==b'%PDF'):\n            with open(out,'wb') as f: f.write(r.content)\n            if os.path.getsize(out)>50000:\n                return True\n            os.remove(out)\n        return False\n    except Exception:\n        return False\n\ndef sanitize(t):\n    return re.sub(r'[\"'^A-Za-z0-9]+'\"','_',t).strip('_')[:80]\n\nfor r in records:\n    if r.get('downloaded'): continue\n    title=r['title']\n    out=f\\\"papers/{r.get('year') or 'unk'}_{sanitize(title)}.pdf\\\"\n    candidates=[]\n\n    # OpenAlex lookup by title\n    try:\n        u=f\\\"https://api.openalex.org/works?search={quote(title)}&per-page=3\\\"\n        resp=s.get(u,timeout=30)\n        if resp.status_code==200:\n            for w in resp.json().get('results',[]):\n                pl=(w.get('primary_location') or {})\n                if pl.get('pdf_url'): candidates.append(pl['pdf_url'])\n                if (pl.get('source') or {}).get('host_organization_name')=='arXiv':\n                    lid=w.get('locations',[])\n                    for loc in lid:\n                        if loc.get('pdf_url'): candidates.append(loc['pdf_url'])\n    except Exception:\n        pass\n\n    # arXiv API by title keyword\n    try:\n        q='all:\\\"'+title.replace('\\\"','')+'\\\"'\n        u=f\\\"http://export.arxiv.org/api/query?search_query={quote(q)}&start=0&max_results=3\\\"\n        txt=s.get(u,timeout=30).text\n        ids=re.findall(r'<id>http://arxiv.org/abs/([\"'^<]+)</id>'\"',txt)\n        for aid in ids:\n            candidates.append(f'https://arxiv.org/pdf/{aid}.pdf')\n    except Exception:\n        pass\n\n    # dedupe preserve order\n    seen=set(); cand=[]\n    for c in candidates:\n        if c and c not in seen:\n            seen.add(c); cand.append(c)\n\n    ok=False\n    for c in cand:\n        if try_download(c,out):\n            ok=True\n            r['downloaded']=True\n            r['pdf_file']=out\n            r.setdefault('extra_pdf_urls',[]).append(c)\n            break\n\n    time.sleep(0.15)\n\njson.dump(records,open(meta_path,'w'),indent=2)\nprint('downloaded_total:',sum(1 for x in records if x.get('downloaded')))\nprint('remaining_missing:',sum(1 for x in records if not x.get('downloaded')))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
